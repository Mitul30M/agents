# API
API_HOST="0.0.0.0"
API_PORT="8000"
DEBUG="false"

# Redis
REDIS_URL="redis://localhost:6379"
# Stream where monitoring publishes incident events
REDIS_CHANNEL="deployment-incidents"
# Stream where monitoring publishes incident events
INCIDENT_STREAM="incident_stream"
# Stream where the diagnosis agent publishes diagnosis reports
DIAGNOSIS_STREAM="diagnosis_stream"
# Stream where application logs are pushed (if using Redis log streaming)
REDIS_LOG_STREAM="app-logs"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="logs/agent.log"
LOG_DIR="logs"
# Path where the Next.js app writes its Winston log file, mounted into this container
APP_LOG_PATH="/app/logs/app.log"

# Monitoring
MONITOR_INTERVAL="10"
MONITORING_AGENT_LLM="llama3.2:latest"

# LLM / Diagnosis (Ollama)
OLLAMA_API_KEY="your-ollama-api-key"
# OLLAMA_BASE_URL="http://host.docker.internal:11434"
DIAGNOSIS_AGENT_LLM="qwen3-coder:480b-cloud"
REMEDIATION_AGENT_LLM="qwen3-coder:480b-cloud"

# Email / Communication (Optional - required for sending incident reports)
# SMTP server for sending emails (e.g., smtp.gmail.com, smtp.office365.com)
SMTP_SERVER="smtp.gmail.com"
# SMTP port (usually 587 for TLS, 465 for SSL)
SMTP_PORT="587"
# Sender email address (e.g., notifications@company.com)
SENDER_EMAIL="your-email@gmail.com"
# SMTP password or app-specific password
SENDER_PASSWORD="your-app-password"
# Developer email address to receive incident reports
DEVELOPER_EMAIL="dev@company.com"